# ==========================================
# 1. Python 环境与缓存 (必须忽略)
# ==========================================
# 忽略虚拟环境文件夹（因为体积大且换台电脑需重新安装）
venv/
env/
.venv/

# 忽略 Python 运行产生的字节码缓存
__pycache__/
*.pyc
*.pyo
*.pyd

# ==========================================
# 2. 项目隐私与核心数据 (绝对不能上传)
# ==========================================
# 忽略 ChromaDB 本地向量数据库文件夹
# （体积非常大，且包含了你切分好的个人隐私笔记片段）
chroma_db/

# 如果你在这个目录下放了真实的私人笔记文件夹，也一定要写在这里
# 例如：my_private_notes/ 

# 忽略环境变量配置文件（通常里面会写 API Key 密码等敏感信息）
.env

# ==========================================
# 3. 操作系统自动生成的隐藏垃圾文件
# ==========================================
# Windows 系统目录缩略图缓存
Thumbs.db
ehthumbs.db
desktop.ini

# macOS 系统文件夹属性缓存
.DS_Store
.AppleDouble
.LSOverride
